{
  "batch_name": "p2_quality_value_timing",
  "mode": "grid",
  "years": 2,
  "default_set": [
    "MARKET_CAP_DIR=data/fmp/market_cap_history",
    "MARKET_CAP_STRICT=True",
    "REBALANCE_FREQ=5",
    "HOLDING_PERIOD=3",
    "REBALANCE_MODE=None",
    "EXECUTION_USE_TRADING_DAYS=True"
  ],
  "families": [
    {
      "name": "quality_v2_timing",
      "factor": "quality_v2",
      "max_candidates": 4,
      "grid": {
        "QUALITY_COMPONENT_MIN_COUNT": [2, 3],
        "QUALITY_COMPONENT_INDUSTRY_ZSCORE": [true, false],
        "QUALITY_LAG_DAYS": [1]
      }
    },
    {
      "name": "value_v2_timing",
      "factor": "value_v2",
      "max_candidates": 4,
      "grid": {
        "VALUE_COMPONENT_MIN_COUNT": [2, 3],
        "VALUE_COMPONENT_INDUSTRY_ZSCORE": [true, false],
        "VALUE_LAG_DAYS": [1]
      }
    },
    {
      "name": "quality_trend_timing",
      "factor": "quality_trend",
      "max_candidates": 4,
      "grid": {
        "QUALITY_TREND_LOOKBACK_DAYS": [126, 252],
        "QUALITY_TREND_LAG_DAYS": [1, 2]
      }
    },
    {
      "name": "momentum_v2_timing",
      "factor": "momentum_v2",
      "max_candidates": 4,
      "grid": {
        "MOMENTUM_LOOKBACK": [84, 126],
        "MOMENTUM_SKIP": [10, 21],
        "MOMENTUM_USE_RESIDUAL": [false],
        "MOMENTUM_LAG_DAYS": [1]
      }
    },
    {
      "name": "low_vol_v2_timing",
      "factor": "low_vol_v2",
      "max_candidates": 4,
      "grid": {
        "LOW_VOL_WINDOW": [60, 120],
        "LOW_VOL_DOWNSIDE_ONLY": [true, false],
        "LOW_VOL_LAG_DAYS": [1]
      }
    }
  ]
}
