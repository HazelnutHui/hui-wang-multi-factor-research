{
  "batch_name": "p3_event_liquidity",
  "mode": "grid",
  "years": 2,
  "default_set": [
    "MARKET_CAP_DIR=data/fmp/market_cap_history",
    "MARKET_CAP_STRICT=True",
    "REBALANCE_FREQ=5",
    "HOLDING_PERIOD=3",
    "REBALANCE_MODE=None",
    "EXECUTION_USE_TRADING_DAYS=True"
  ],
  "families": [
    {
      "name": "pead_v2_threshold_age",
      "factor": "pead_v2",
      "max_candidates": 4,
      "grid": {
        "SUE_THRESHOLD": [0.3, 0.5],
        "PEAD_EVENT_MAX_AGE_DAYS": [0, 1],
        "PEAD_LAG_DAYS": [1]
      }
    },
    {
      "name": "pead_v2_timing",
      "factor": "pead_v2",
      "max_candidates": 4,
      "grid": {
        "LOOKBACK_QUARTERS": [6, 8],
        "PEAD_USE_TRADING_DAY_SHIFT": [true, false],
        "DATE_SHIFT_DAYS": [0],
        "PEAD_LAG_DAYS": [1]
      }
    },
    {
      "name": "reversal_v2_event",
      "factor": "reversal_v2",
      "max_candidates": 4,
      "grid": {
        "REVERSAL_LOOKBACK": [3, 5],
        "REVERSAL_EARNINGS_FILTER_DAYS": [1, 2],
        "REVERSAL_LAG_DAYS": [1]
      }
    },
    {
      "name": "turnover_shock_event",
      "factor": "turnover_shock",
      "max_candidates": 4,
      "grid": {
        "TURNOVER_SHOCK_SHORT": [12, 20],
        "TURNOVER_SHOCK_LONG": [80, 160],
        "TURNOVER_SHOCK_MIN_OBS": [60],
        "TURNOVER_SHOCK_LAG_DAYS": [1]
      }
    },
    {
      "name": "vol_regime_event",
      "factor": "vol_regime",
      "max_candidates": 4,
      "grid": {
        "VOL_REGIME_SHORT": [12, 20],
        "VOL_REGIME_LONG": [80, 160],
        "VOL_REGIME_MIN_OBS": [60],
        "VOL_REGIME_LAG_DAYS": [1, 2]
      }
    }
  ]
}
